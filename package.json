    "hono-react-router-adapter": "^0.6.5",
    "isbot": "^5.1.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.14.1"
  },
  "devDependencies": {
    "@hono/vite-dev-server": "^0.25.1",
    "@react-router/cloudflare": "^7.14.1",
    "@react-router/dev": "^7.14.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
